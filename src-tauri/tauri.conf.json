{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KittyNest",
  "version": "0.1.0",
  "identifier": "com.kittynest.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5184",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KittyNest",
        "label": "main",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "capabilities": ["main"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns", "icons/icon.png"]
  }
}
